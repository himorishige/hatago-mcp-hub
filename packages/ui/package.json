{
  "name": "@himorishige/hatago-ui",
  "version": "0.0.1",
  "description": "Web UI for Hatago MCP Hub - lightweight dashboard for server management",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./types": "./dist/types.js"
  },
  "scripts": {
    "dev": "honox dev",
    "build": "pnpm build:types && pnpm build:js",
    "build:types": "tsc --declaration --emitDeclarationOnly",
    "build:js": "vite build",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist || true"
  },
  "dependencies": {
    "autoprefixer": "^10.4.21",
    "daisyui": "^5.1.7",
    "hono": "^4.6.3",
    "honox": "^0.1.24",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.13",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^22.1.0",
    "typescript": "^5.5.4",
    "vite": "^5.4.2"
  },
  "peerDependencies": {
    "@himorishige/hatago-core": "workspace:*",
    "@himorishige/hatago-hub": "workspace:*"
  },
  "keywords": [
    "mcp",
    "hono",
    "honox",
    "ui",
    "dashboard",
    "web",
    "ssr",
    "islands"
  ]
}
